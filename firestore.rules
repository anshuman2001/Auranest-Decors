rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = a user whose auth token carries a custom claim { admin: true }.
    // Granted once via api/grant-admin. The Admin SDK (server) bypasses all
    // rules, so server-side order fulfilment is unaffected by these.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ── Customers — owner-only read & write (SEC-01) ──
    // Phone-existence lookup at login is handled server-side (api/lookup-phone),
    // so no public read is required.
    match /customers/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /addresses/{addrId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Orders — customers create their own; owner reads; only admin mutates ──
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null &&
                       (isAdmin() || request.auth.uid == resource.data.customerId);
      allow update, delete: if isAdmin();
    }

    // ── Catalogue & store content — public read, admin-only write (SEC-06) ──
    match /products/{productId} { allow read: if true; allow write: if isAdmin(); }
    match /offers/{offerId}    { allow read: if true; allow write: if isAdmin(); }
    match /settings/{docId}    { allow read: if true; allow write: if isAdmin(); }
    match /config/{docId}      { allow read: if true; allow write: if isAdmin(); }

    // ── Internal collections (written only by the Admin SDK) — no client access ──
    match /_ratelimit/{doc} { allow read, write: if false; }
    match /_diag/{doc}      { allow read, write: if false; }

    // Deny everything else by default.
    match /{document=**} { allow read, write: if false; }
  }
}
