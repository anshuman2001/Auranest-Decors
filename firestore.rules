rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Customers — owner-only read & write. Phone-existence lookup during login
    // is handled server-side (api/lookup-phone) via the Admin SDK, so no public
    // read is needed. This closes the PII-exposure hole (SEC-01).
    match /customers/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Addresses subcollection — owner only
      match /addresses/{addrId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Orders — authenticated users can create; owner can read their own
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.uid == resource.data.customerId;
      allow update, delete: if false;
    }

    // Products — public read, no client writes
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
