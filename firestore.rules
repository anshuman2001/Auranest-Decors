rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Customers — anyone can read (for phone lookup during login),
    // only the account owner can write their own doc
    match /customers/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Addresses subcollection — owner only
      match /addresses/{addrId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Orders — authenticated users can create; owner can read their own
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.uid == resource.data.customerId;
      allow update, delete: if false;
    }

    // Products — public read, no client writes
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
